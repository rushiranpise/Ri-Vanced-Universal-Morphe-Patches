      "dependencies": [],
      "compatiblePackages": null,
      "options": [
        {
          "key": "Package name",
          "title": null,
          "description": "The name of the package to rename the app to.",
          "required": true,
          "type": "kotlin.String",
          "default": "Default",
          "values": {
            "Default": "Default"
          }
        },
        {
          "key": "Update permissions",
          "title": null,
          "description": "Update compatibility receiver permissions. Enabling this can fix installation errors, but this can also break features in certain apps.",
          "required": false,
          "type": "kotlin.Boolean",
          "default": false,
          "values": null
        },
        {
          "key": "Update providers",
          "title": null,
          "description": "Update provider names declared by the app. Enabling this can fix installation errors, but this can also break features in certain apps.",
          "required": false,
          "type": "kotlin.Boolean",
          "default": false,
          "values": null
        }
      ]
    },
    {
      "name": "Change version code",
      "description": "Changes the version code of the app. This will turn off app store updates and allows downgrading an existing app install to an older app version.",
      "default": false,
      "dependencies": [],
      "compatiblePackages": null,
      "options": [
        {
          "key": "Version code",
          "title": null,
          "description": "The version code to use. Using the highest value turns off app store updates and allows downgrading an existing app install to an older app version.",
          "required": true,
          "type": "kotlin.Int",
          "default": 2147483647,
          "values": {
            "Lowest": 1,
            "Highest": 2147483647
          }
        }
      ]
    },
    {
      "name": "Custom network security",
      "description": "Allows trusting custom certificate authorities for a specific domain.",
      "default": false,
      "dependencies": [],
      "compatiblePackages": null,
      "options": [
        {
          "key": "Target domains",
          "title": null,
          "description": "List of domains to which the custom trust configuration will be applied (one domain per entry).",
          "required": true,
          "type": "kotlin.collections.List<kotlin.String>",
          "default": [
            "example.com"
          ],
          "values": null
        },
        {
          "key": "Include subdomains",
          "title": null,
          "description": "Applies the configuration to all subdomains of the target domains.",
          "required": true,
          "type": "kotlin.Boolean",
          "default": false,
          "values": null
        },
        {
          "key": "Custom CA file paths",
          "title": null,
          "description": "List of paths to files in PEM or DER format (one file path per entry).\n\nMakes an app trust the provided custom certificate authorities (CAs),\nfor the specified domains, and if the option \"Include Subdomains\" is enabled then also the subdomains.\n\n\nCA files will be bundled in res/raw/ of resulting APK",
          "required": false,
          "type": "kotlin.collections.List<kotlin.String>",
          "default": null,
          "values": null
        },
        {
          "key": "Trust user added CAs",
          "title": null,
          "description": "Makes an app trust certificates from the Android user store for the specified domains, and if the option \"Include Subdomains\" is enabled then also the subdomains.",
          "required": true,
          "type": "kotlin.Boolean",
          "default": false,
          "values": null
        },
        {
          "key": "Trust system CAs",
          "title": null,
          "description": "Makes an app trust certificates from the Android system store for the specified domains, and and if the option \"Include Subdomains\" is enabled then also the subdomains.",
          "required": true,
          "type": "kotlin.Boolean",
          "default": true,
          "values": null
        },
        {
          "key": "Allow cleartext traffic (HTTP)",
          "title": null,
          "description": "Allows unencrypted HTTP traffic for the specified domains, and if \"Include Subdomains\" is enabled then also the subdomains.",
          "required": true,
          "type": "kotlin.Boolean",
          "default": false,
          "values": null
        },
        {
          "key": "Override certificate pinning",
          "title": null,
          "description": "Overrides certificate pinning for the specified domains and their subdomains if the option \"Include Subdomains\" is enabled to allow inspecting app traffic via a proxy.",
          "required": true,
          "type": "kotlin.Boolean",
          "default": false,
          "values": null
        }
      ]
    },
