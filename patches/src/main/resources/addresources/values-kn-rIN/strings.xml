            <string name="rivanced_gms_core_settings_title">GmsCore ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ತೆರೆಯಿರಿ</string>
            <string name="rivanced_gms_core_settings_summary">GmsCore ಸೆಟ್ಟಿಂಗ್‌ಗಳು</string>
