        <patch id="misc.gms.gmsCoreSupportResourcePatch">
            <string name="rivanced_gms_core_screen_title">GmsCore</string>
            <string name="rivanced_gms_core_screen_summary">GmsCore ಗೆ ಸಂಬಂಧಿಸಿದ ಸೆಟ್ಟಿಂಗ್‌ಗಳು</string>
            <string name="rivanced_gms_core_check_updates_title">GmsCore ನವೀಕರಣಗಳಿಗಾಗಿ ಪರಿಶೀಲಿಸಿ</string>
            <string name="rivanced_gms_core_check_updates_summary_on">ನವೀಕರಣಗಳ ಪರಿಶೀಲನೆ ಸಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ</string>
